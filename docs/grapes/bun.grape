---
phase: env
depend_executable:
  binary: bun
  search_paths:
    - $HOME/.bun/bin
  version_args:
    - --version
  version_regex: "([0-9]+\\.[0-9]+\\.[0-9]+)"
---
--#ifdef PWSH

--#elif NUSHELL

--#else
export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
export PATH="$BUN_INSTALL/bin:$PATH"
--#endif
