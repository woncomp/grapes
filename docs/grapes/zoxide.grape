---
phase: main
depend_executable:
  binary: zoxide
  search_paths:
    - ~/.local/bin
    - $HOME/.cargo/bin
  version_args:
    - --version
  version_regex: "([0-9]+\\.[0-9]+\\.[0-9]+)"
---

#ifdef PWSH

zoxide init powershell | Out-String | Invoke-Expression

#elif NUSHELL

zoxide init nushell | save -f ~/.zoxide.nu
source ~/.zoxide.nu

#else

eval "$(zoxide init $GRAPES_SHELL)"

#endif
