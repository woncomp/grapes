format = """
[Óā∂](#9A348E)\
$os\
$time\
$hostname\
[Óāį](bg:#DA627D fg:#9A348E)\
[Óāį](fg:#DA627D bg:#FCA17D)\
$git_branch\
$git_status\
[Óāį](fg:#FCA17D bg:#86BBD8)\
$c\
$elixir\
$elm\
$golang\
$gradle\
$haskell\
$java\
$julia\
$nodejs\
$nim\
$rust\
$scala\
[Óāį](fg:#86BBD8 bg:#06969A)\
$docker_context\
[Óāį](fg:#06969A bg:#33658A)\
$directory\
[Óāį ](fg:#33658A)\
$cmd_duration
$character \
"""

# Disable the blank line at the start of the prompt
# add_newline = false

# You can also replace your username with a neat symbol like ÔĄ†  or disable this
# and use the os module below
[hostname]
style = "bg:#9A348E"
format = '[$ssh_symbol$hostname ]($style)'
disabled = false
ssh_only = false

# An alternative to the username module which displays a symbol that
# represents the current operating system
[os]
style = "bg:#9A348E"
format = "[$symbol]($style)"
disabled = false             # Disabled by default

[directory]
style = "bg:#33658A"
format = "[ $path ]($style)"
truncation_length = 9
truncation_symbol = "‚Ä¶/"
truncate_to_repo = false

# Here is how you can shorten some long paths by text replacement
# similar to mapped_locations in Oh My Posh:
[directory.substitutions]
"Documents" = "ůįąô "
"Downloads" = "ÔÄô "
"Music" = "ÔÄĀ "
"Pictures" = "ÔÄĺ "
# Keep in mind that the order matters. For example:
# "Important Documents" = " ůįąôÔĄ™ "
# will not be replaced, because "Documents" was already substituted before.
# So either put "Important Documents" before "Documents" or use the substituted version:
# "Important ůįąô " = " ůįąôÔĄ™ "

[c]
symbol = "Óėě "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[docker_context]
symbol = "ÔĆą "
style = "bg:#06969A"
format = '[ $symbol $context ]($style)'

[elixir]
symbol = "ÓČĶ "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[elm]
symbol = "Óė¨ "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[git_branch]
symbol = "Ôźė"
style = "bg:#FCA17D"
format = '[ $symbol $branch ]($style)'

[git_status]
style = "bg:#FCA17D"
format = '[$all_status$ahead_behind ]($style)'

[golang]
symbol = "Óėß "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[gradle]
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[haskell]
symbol = "ÓĚ∑ "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[java]
symbol = "ÓČĖ "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[julia]
symbol = "Óė§ "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[nodejs]
symbol = "Óúė"
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[nim]
symbol = "ůįÜ• "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[rust]
symbol = "Óě®"
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[scala]
symbol = "Óú∑ "
style = "bg:#86BBD8"
format = '[ $symbol ($version) ]($style)'

[time]
disabled = false
time_format = "%R"          # Hour:Minute Format
style = "bg:#9A348E"
format = '[$time ]($style)'

[cmd_duration]
show_milliseconds = true
format = "Óęī in $duration "
style = "bg:lavender"
disabled = false
show_notifications = true
min_time_to_notify = 1
min_time = 900