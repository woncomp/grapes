---
phase: main
depend_executable:
  binary: zoxide
  search_paths:
    - ~/.local/bin
    - $HOME/.cargo/bin
  version_args:
    - --version
  version_regex: "([0-9]+\\.[0-9]+\\.[0-9]+)"
---
#ifdef BASH
eval "$(zoxide init bash)"
#elif ZSH
eval "$(zoxide init zsh)"
#elif PWSH
zoxide init powershell | Out-String | Invoke-Expression
#endif
