---
phase: main
depend_executable:
  binary: fnm
  version_args:
    - --version
  version_regex: "([0-9]+\\.[0-9]+\\.[0-9]+)"
---
#ifdef BASH
eval "$(fnm env --use-on-cd --shell bash)"
#elif ZSH
eval "$(fnm env --use-on-cd --shell zsh)"
#elif POWERSHELL
fnm env --use-on-cd --shell powershell | Out-String | Invoke-Expression
#endif
